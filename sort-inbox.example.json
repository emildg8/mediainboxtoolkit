{
  "schemaVersion": 1,
  "meta": {
    "description": "Нейтральный шаблон: замените nasShareRoot и относительные пути. Персональный пример: sort-inbox.library-layout-emilian.example.json. Скелет внутри Sort: sort-inbox.video-under-sort*.example.json. Опционально в folders: skeletonProfile (ascii|cyrillic, метка), skeletonExtraRelatives [] — относительно nasShareRoot для New-MediaInboxDestinationSkeleton.ps1; workspaceSeriesToolkitSubfolders [] — подпапки под Sort\\Video для Organize-SortVideoUnderSort.ps1.",
    "updatedAt": "2026-05-05"
  },
  "nasShareRoot": "\\\\FILESERVER\\media",
  "inboxRelative": "Video\\Sort",
  "destinations": {
    "series": "Video\\Сериалы",
    "cartoons": "Video\\Мультсериалы",
    "cartoonMovies": "Video\\Мультики",
    "movies": "Video\\Фильмы",
    "anime": "Video\\Аниме",
    "animeSeries": "Video\\Анимесериалы",
    "review": "Video\\_SortReview"
  },
  "destinationsByKind": {
    "series_episode": "series",
    "series_related_movie": "movies",
    "cartoon_series_episode": "cartoons",
    "cartoon_movie": "cartoonMovies",
    "cartoon_series_related_movie": "cartoonMovies",
    "anime_series_episode": "animeSeries",
    "anime_series_related": "animeSeries",
    "anime_ova": "animeSeries",
    "anime_movie": "anime",
    "movie": "movies",
    "unknown": "movies",
    "bluray_remux": "movies"
  },
  "destinationsByKindMinConfidence": 40,
  "tmdbKindRefinement": {
    "enabled": true
  },
  "folders": {
    "createDestinationRootsOnApply": true,
    "skeletonProfile": "neutral",
    "skeletonExtraRelatives": []
  },
  "classification": {
    "folderSeasonContext": {
      "enabled": true,
      "orphanSeasonFolderSeriesMap": []
    },
    "tvSpecialFilenameBoost": { "enabled": true },
    "movies": { "allowMissingYearIfTmdbMatched": true },
    "webTmdbResolve": { "enabled": true },
    "featureMeter": { "minSecondsForFullFeature": 3600 },
    "shortFormEpisodeTitleGuess": {
      "enabled": true,
      "maxDurationSec": 1500,
      "maxBasenameChars": 72,
      "maxSeasonsToScanPerShow": 28,
      "pathContainsToTmdbTvId": [
        { "ifPathContains": "Robot Chicken", "tmdbTvId": 709 }
      ]
    }
  },
  "scope": {
    "videoOnly": true
  },
  "safety": {
    "requireSourceUnderInbox": true,
    "skipSourceIfUnderLibrary": true,
    "libraryRootRelatives": [
      "Video\\Сериалы",
      "Video\\Мультсериалы",
      "Video\\Мультики",
      "Video\\Фильмы",
      "Video\\Аниме",
      "Video\\Анимесериалы"
    ]
  },
  "preferCartoonsSubfolder": false,
  "displayNames": {
    "tmdbLanguage": "ru-RU",
    "preferCyrillic": true
  },
  "episodeTitleFallback": "Серия {0}",
  "blurayRemux": {
    "enabled": true
  },
  "seasonFolderFormat": "Сезон {0}",
  "videoExtensions": [ "mkv", "mp4", "avi", "m4v", "mov", "wmv", "webm", "mpeg", "mpg" ],
  "filenameTemplates": {
    "series": "{Series} - S{Season:D2}E{Episode:D2} - {Title}.{Ext}",
    "movie": "{Title}.{Ext}"
  }
}
