    "anime": "Video\\Sort\\Video\\anime",
    "animeSeries": "Video\\Sort\\Video\\animeSeries",
    "review": "Video\\Sort\\Video\\_review"
  },
  "destinationsByKind": {
    "series_episode": "series",
    "series_related_movie": "movies",
    "cartoon_series_episode": "cartoons",
    "cartoon_movie": "cartoonMovies",
    "cartoon_series_related_movie": "cartoonMovies",
    "anime_series_episode": "animeSeries",
