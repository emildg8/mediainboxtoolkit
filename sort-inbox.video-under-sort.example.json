  "destinationsByKindMinConfidence": 40,
  "tmdbKindRefinement": { "enabled": true },
  "folders": {
    "createDestinationRootsOnApply": true,
    "skeletonProfile": "ascii",
    "workspaceSeriesToolkitSubfolders": [ "series", "cartoons", "animeSeries" ],
    "skeletonExtraRelatives": [
      "Video\\Sort\\Video\\documentaries",
      "Video\\Sort\\Video\\concerts",
      "Video\\Sort\\Video\\sports",
      "Video\\Sort\\Video\\standUp",
      "Video\\Sort\\Video\\kids",
      "Video\\Sort\\Video\\reality",
      "Video\\Sort\\Video\\musicVideos",
      "Video\\Sort\\Video\\_staging",
      "Video\\Sort\\Video\\_extras"
    ]
