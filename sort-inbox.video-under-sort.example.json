  "classification": {
    "folderSeasonContext": {
      "enabled": true,
      "orphanSeasonFolderSeriesMap": [
        { "folderMatch": "3 season", "seriesGuess": "King of the Hill" }
      ]
    },
    "tvSpecialFilenameBoost": { "enabled": true },
    "movies": { "allowMissingYearIfTmdbMatched": true },
    "webTmdbResolve": { "enabled": true },
    "featureMeter": { "minSecondsForFullFeature": 3600 },
    "cartoonMovieBasenameRegexes": [
      "(?i)Alice\\.(?:in\\.)?Wonderland\\.1951"
    ],
    "seriesQueryRewrites": [
      { "pattern": "(?i)The Wednesday Play", "seriesGuess": "Wednesday", "matchField": "seriesGuessOrBasename" },
      { "pattern": "(?i)Peacemakers", "seriesGuess": "Peacemaker", "matchField": "seriesGuessOrBasename" },
      { "pattern": "(?i)Invincible\\.2021", "seriesGuess": "Invincible", "matchField": "basename" },
      { "pattern": "^Foundations of the West$", "seriesGuess": "Foundation", "matchField": "seriesGuess" },
      { "pattern": "^Bridging the Expanse$", "seriesGuess": "The Expanse", "matchField": "seriesGuess" },
      { "pattern": "^The Wheel of Time Origins$", "seriesGuess": "The Wheel of Time", "matchField": "seriesGuess" },
      { "pattern": "^關於未知的我們$", "seriesGuess": "Robot Chicken", "matchField": "seriesGuess" },
      { "pattern": "(?i)Подозрительная сова", "seriesGuess": "Подозрительная сова", "matchField": "relativePath" }
    ],
    "seriesFolderByTmdbTvId": {
      "95557": "Непобедимый"
    }
  },
  "scope": {
    "videoOnly": true,
    "excludeDirectoryNames": [ "Video", "_Workspace" ]
  },
  "safety": {
    "requireSourceUnderInbox": true,
    "skipSourceIfUnderLibrary": true,
    "libraryRootRelatives": [
      "Video\\Сериалы",
      "Video\\Мультсериалы",
      "Video\\Мультики",
      "Video\\Фильмы",
      "Video\\Аниме",
      "Video\\Анимесериалы"
    ]
  },
  "preferCartoonsSubfolder": false,
  "displayNames": { "tmdbLanguage": "ru-RU", "preferCyrillic": true },
  "episodeTitleFallback": "Серия {0}",
  "blurayRemux": { "enabled": true },
  "seasonFolderFormat": "Сезон {0}",
  "videoExtensions": [ "mkv", "mp4", "avi", "m4v", "mov", "wmv", "webm", "mpeg", "mpg" ],
  "filenameTemplates": {
    "series": "{Series} - S{Season:D2}E{Episode:D2} - {Title}.{Ext}",
    "movie": "{Title}.{Ext}"
  }
}
